ZETA_CXX_STANDARD=20
ZETA_BOOST_VERSION=1.90.0
ZETA_JEMALLOC_VERSION=5.3.0
ZETA_FMT_VERSION=12.1.0
ZETA_INSTALL_PREFIX="${ZETA_INSTALL_PREFIX:-$HOME/.local}"

ZETA_ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ZETA_BUILDER_DIR="${ZETA_ROOT_DIR}/builder"
ZETA_THIRD_PARTY_DIR="${ZETA_ROOT_DIR}/3rd_party"

: "${ZETA_HPX_SRC_DIR:=${ZETA_THIRD_PARTY_DIR}/hpx}"
: "${ZETA_FOLLY_SRC_DIR:=${ZETA_THIRD_PARTY_DIR}/folly}"
: "${ZETA_ABSEIL_SRC_DIR:=${ZETA_THIRD_PARTY_DIR}/abseil-cpp}"
: "${ZETA_NNG_SRC_DIR:=${ZETA_THIRD_PARTY_DIR}/nng}"
: "${ZETA_TASKFLOW_SRC_DIR:=${ZETA_THIRD_PARTY_DIR}/taskflow}"
: "${ZETA_RAPIDJSON_SRC_DIR:=${ZETA_THIRD_PARTY_DIR}/rapidjson}"
: "${ZETA_ZPP_SRC_DIR:=${ZETA_THIRD_PARTY_DIR}/zpp}"